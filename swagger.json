{
  "openapi": "3.0.0",
  "info": {
    "title": "FitTrack API",
    "version": "1.0.0",
    "description": "Fitness tracking API for managing users, workouts, meals, and goals with JWT authentication"
  },
  "servers": [
    { "url": "https://final-project-27de.onrender.com", "description": "Production (Render)" },
    { "url": "http://localhost:5000", "description": "Local development" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter JWT token from /api/users/login (without 'Bearer ' prefix)"
      }
    },
    "schemas": {
      "UserInput": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "example": "Maria Gonzalez" },
          "email": { "type": "string", "format": "email", "example": "maria.gonzalez@email.com" },
          "password": { "type": "string", "minLength": 8, "example": "FitTrack2026!" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d0" },
          "name": { "type": "string", "example": "Maria Gonzalez" },
          "email": { "type": "string", "example": "maria.gonzalez@email.com" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-05T14:30:00.000Z" }
        }
      },

      "LoginInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "maria.gonzalez@email.com" },
          "password": { "type": "string", "example": "FitTrack2026!" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },

      "WorkoutInput": {
        "type": "object",
        "required": ["date", "type", "duration"],
        "properties": {
          "date": { "type": "string", "format": "date", "example": "2026-04-08" },
          "type": { "type": "string", "enum": ["Cardio", "Strength", "HIIT", "Yoga", "Mobility", "Sports", "Other"], "example": "Strength" },
          "duration": { "type": "integer", "example": 65 },
          "caloriesBurned": { "type": "integer", "example": 480 },
          "notes": { "type": "string", "example": "Focused on squats, bench press and deadlifts. Felt very strong today." }
        }
      },
      "Workout": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d1" },
          "userId": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d0" },
          "date": { "type": "string", "format": "date", "example": "2026-04-08" },
          "type": { "type": "string", "example": "Strength" },
          "duration": { "type": "integer", "example": 65 },
          "caloriesBurned": { "type": "integer", "example": 480 },
          "notes": { "type": "string", "example": "Focused on squats, bench press and deadlifts. Felt very strong today." },
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-08T09:15:00.000Z" },
          "updatedAt": { "type": "string", "format": "date-time", "example": "2026-04-08T09:15:00.000Z" }
        }
      },

      "MealInput": {
        "type": "object",
        "required": ["date", "mealType", "foodItems", "calories"],
        "properties": {
          "date": { "type": "string", "format": "date", "example": "2026-04-08" },
          "mealType": { "type": "string", "enum": ["Breakfast", "Lunch", "Dinner", "Snack"], "example": "Breakfast" },
          "foodItems": { "type": "string", "example": "Oatmeal with banana, peanut butter, and whey protein" },
          "calories": { "type": "integer", "example": 520 },
          "protein": { "type": "number", "example": 35 },
          "carbs": { "type": "number", "example": 68 },
          "fats": { "type": "number", "example": 14 },
          "notes": { "type": "string", "example": "Pre-workout breakfast - high energy" }
        }
      },
      "Meal": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d2" },
          "userId": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d0" },
          "date": { "type": "string", "format": "date", "example": "2026-04-08" },
          "mealType": { "type": "string", "example": "Breakfast" },
          "foodItems": { "type": "string", "example": "Oatmeal with banana, peanut butter, and whey protein" },
          "calories": { "type": "integer", "example": 520 },
          "protein": { "type": "number", "example": 35 },
          "carbs": { "type": "number", "example": 68 },
          "fats": { "type": "number", "example": 14 },
          "notes": { "type": "string", "example": "Pre-workout breakfast - high energy" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-08T07:45:00.000Z" }
        }
      },

      "GoalInput": {
        "type": "object",
        "required": ["title", "targetValue", "unit"],
        "properties": {
          "title": { "type": "string", "example": "Lose 8kg" },
          "description": { "type": "string", "example": "Get in shape for summer vacation" },
          "targetValue": { "type": "number", "example": 8 },
          "currentValue": { "type": "number", "default": 0, "example": 2.5 },
          "unit": { "type": "string", "example": "kg" },
          "deadline": { "type": "string", "format": "date", "example": "2026-07-20" }
        }
      },
      "Goal": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d3" },
          "userId": { "type": "string", "example": "67f8a1b2c3d4e5f6a7b8c9d0" },
          "title": { "type": "string", "example": "Lose 8kg" },
          "description": { "type": "string", "example": "Get in shape for summer vacation" },
          "targetValue": { "type": "number", "example": 8 },
          "currentValue": { "type": "number", "example": 2.5 },
          "unit": { "type": "string", "example": "kg" },
          "deadline": { "type": "string", "format": "date", "example": "2026-07-20" },
          "status": { "type": "string", "enum": ["active", "completed", "failed"], "example": "active" },
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-05T10:20:00.000Z" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "description": "Retrieve a list of all registered users (passwords hidden)",
        "responses": {
          "200": {
            "description": "List of users",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } }
          },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "summary": "Register a new user",
        "description": "Create a new user. Password is automatically hashed.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserInput" },
              "example": {
                "name": "Maria Gonzalez",
                "email": "maria.gonzalez@email.com",
                "password": "FitTrack2026!"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "400": { "description": "Validation error" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Login user",
        "description": "Authenticate user and return JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginInput" },
              "example": {
                "email": "maria.gonzalez@email.com",
                "password": "FitTrack2026!"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } }
          },
          "400": { "description": "Invalid credentials" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Get user by ID",
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "User found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "404": { "description": "User not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "summary": "Update user by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInput" } } }
        },
        "responses": {
          "200": { "description": "User updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "400": { "description": "Validation error" },
          "404": { "description": "User not found" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "summary": "Delete user by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "User deleted" },
          "404": { "description": "User not found" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },

    "/api/workouts": {
      "get": {
        "summary": "Get all workouts",
        "description": "Retrieve all workouts (populated with user info)",
        "responses": {
          "200": { "description": "List of workouts", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Workout" } } } } },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "summary": "Create a new workout",
        "security": [{ "bearerAuth": [] }],
        "description": "Add a new workout linked to the authenticated user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutInput" },
              "example": {
                "date": "2026-04-08",
                "type": "Strength",
                "duration": 65,
                "caloriesBurned": 480,
                "notes": "Focused on squats, bench press and deadlifts. Felt very strong today."
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Workout created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workout" } } } },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/workouts/{workoutId}": {
      "get": {
        "summary": "Get workout by ID",
        "parameters": [{ "in": "path", "name": "workoutId", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Workout found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workout" } } } },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "summary": "Update workout",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "workoutId", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkoutInput" } } }
        },
        "responses": {
          "200": { "description": "Workout updated" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "summary": "Delete workout",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "workoutId", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Workout deleted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/workouts/user/{userId}": {
      "get": {
        "summary": "Get workouts by user",
        "parameters": [{ "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "List of user's workouts" }, "500": { "description": "Server error" } }
      }
    },
    "/api/workouts/date/{date}": {
      "get": {
        "summary": "Get workouts by date",
        "parameters": [{ "in": "path", "name": "date", "required": true, "schema": { "type": "string", "format": "date" }, "example": "2026-04-08" }],
        "responses": { "200": { "description": "Workouts on that date" }, "500": { "description": "Server error" } }
      }
    },

    "/api/meals": {
      "get": {
        "summary": "Get all meals",
        "responses": { "200": { "description": "List of meals" }, "500": { "description": "Server error" } }
      },
      "post": {
        "summary": "Create a new meal",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MealInput" },
              "example": {
                "date": "2026-04-08",
                "mealType": "Breakfast",
                "foodItems": "Oatmeal with banana, peanut butter, and whey protein",
                "calories": 520,
                "protein": 35,
                "carbs": 68,
                "fats": 14,
                "notes": "Pre-workout breakfast - high energy"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Meal created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/meals/{mealId}": {
      "get": { "summary": "Get meal by ID", "parameters": [{ "in": "path", "name": "mealId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Meal found" }, "404": { "description": "Not found" } } },
      "put": {
        "summary": "Update meal",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "mealId", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MealInput" } } } },
        "responses": { "200": { "description": "Meal updated" }, "401": { "description": "Unauthorized" } }
      },
      "delete": {
        "summary": "Delete meal",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "mealId", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Meal deleted" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/meals/user/{userId}": {
      "get": { "summary": "Get meals by user", "parameters": [{ "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "User's meals" } } }
    },
    "/api/meals/date/{date}": {
      "get": { "summary": "Get meals by date", "parameters": [{ "in": "path", "name": "date", "required": true, "schema": { "type": "string", "format": "date" } }], "responses": { "200": { "description": "Meals on that date" } } }
    },

    "/api/goals": {
      "get": { "summary": "Get all goals", "responses": { "200": { "description": "List of goals" } } },
      "post": {
        "summary": "Create a new goal",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GoalInput" },
              "example": {
                "title": "Lose 8kg",
                "description": "Get in shape for summer vacation",
                "targetValue": 8,
                "currentValue": 2.5,
                "unit": "kg",
                "deadline": "2026-07-20"
              }
            }
          }
        },
        "responses": { "201": { "description": "Goal created" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/goals/{goalId}": {
      "get": { "summary": "Get goal by ID", "parameters": [{ "in": "path", "name": "goalId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Goal found" } } },
      "put": {
        "summary": "Update goal (including progress)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "goalId", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GoalInput" } } } },
        "responses": { "200": { "description": "Goal updated" }, "401": { "description": "Unauthorized" } }
      },
      "delete": {
        "summary": "Delete goal",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "goalId", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Goal deleted" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/goals/user/{userId}": {
      "get": { "summary": "Get goals by user", "parameters": [{ "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "User's goals" } } }
    }
  }
}